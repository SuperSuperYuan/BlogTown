# Chat-model connection for the /ask RAG chat (sourced by scripts/run.sh).
# Copy to config/atlas-chat.env (gitignored) and fill in your values.
# Each var falls back to the matching HERMES_* setting if unset.
ATLAS_CHAT_BASE_URL=https://api.deepseek.com
ATLAS_CHAT_MODEL=deepseek-chat
ATLAS_CHAT_API_KEY=sk-your-key-here
